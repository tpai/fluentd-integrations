# ─── Component versions ────────────────────────────────────────────────────────
GRAYLOG_VERSION=6.1
MONGO_VERSION=7.0
OPENSEARCH_VERSION=2.17.0

# ─── Graylog HTTP ──────────────────────────────────────────────────────────────
# Must end with /
GRAYLOG_HTTP_EXTERNAL_URI=http://127.0.0.1:9000/

# ─── Graylog credentials ───────────────────────────────────────────────────────
# Generate with: make gen-secret
# Minimum 16 characters; 96+ recommended.
GRAYLOG_PASSWORD_SECRET=change-me-use-make-gen-secret-to-get-a-real-value-that-is-long-enough-for-production

# SHA-256 hash of the admin password.
# Generate with: make hash-password
# Default below is SHA-256("admin") — DO NOT use in shared environments.
GRAYLOG_ROOT_PASSWORD_SHA2=8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918

# ─── CEF input ports ───────────────────────────────────────────────────────────
CEF_PORT=5514
